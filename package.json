{
  "name": "propieya",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/TeknoAriel/PropieYa.git"
  },
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm build",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:sql:apply": "pnpm exec tsx scripts/apply-docs-sql.ts",
    "db:schema:local": "bash scripts/db-schema-local.sh",
    "db:studio": "pnpm --filter @propieya/database db:studio",
    "infra:test": "bash scripts/infra-test.sh",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "import:yumblin": "pnpm exec tsx scripts/import-yumblin-json.ts",
    "import:yumblin:reimport": "pnpm exec tsx scripts/import-yumblin-json.ts -- --reimport",
    "seed:org": "pnpm exec tsx scripts/seed-org-for-import.ts",
    "publish:imported": "pnpm exec tsx scripts/publish-imported-drafts.ts",
    "sync-search:local": "pnpm exec tsx scripts/sync-search-local.ts",
    "dedup:apply": "pnpm exec tsx scripts/apply-dedup-listings.ts",
    "reindex:es": "pnpm sync-search:local",
    "reindex:bonsai": "USE_OPENSEARCH=1 pnpm exec tsx scripts/sync-search-local.ts",
    "audit:listing-types": "pnpm exec tsx scripts/audit-listing-property-types.ts",
    "reclassify:listing-types": "pnpm exec tsx scripts/reclassify-listing-property-types.ts",
    "audit:yumblin-fields": "pnpm exec tsx scripts/audit-yumblin-fields.ts",
    "audit:prod:leads": "pnpm exec tsx scripts/audit-prod-leads-schema.ts",
    "apply:prod:leads-schema": "pnpm exec tsx scripts/apply-prod-leads-schema-fix.ts",
    "diff:import-types": "pnpm exec tsx scripts/diff-import-property-types.ts",
    "sample:feed-types": "pnpm exec tsx scripts/sample-feed-property-types.ts",
    "verificar:prod": "bash scripts/verificar-produccion.sh",
    "diagnostico:prod": "bash scripts/diagnostico-produccion.sh",
    "verificar:deploy": "bash scripts/verificar-deploy-esperar.sh --wait 3",
    "verificar:ruta-produccion": "bash scripts/verificar-ruta-produccion.sh",
    "verify:repo-remote": "bash scripts/verify-repo-remote.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "argon2": "^0.31.2",
    "dotenv": "^16.4.0",
    "husky": "^9.0.0",
    "postgres": "3.4.8",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
