{
  "name": "propieya",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm build",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @propieya/database db:studio",
    "infra:test": "bash scripts/infra-test.sh",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "import:yumblin": "pnpm exec tsx scripts/import-yumblin-json.ts",
    "seed:org": "pnpm exec tsx scripts/seed-org-for-import.ts",
    "publish:imported": "pnpm exec tsx scripts/publish-imported-drafts.ts",
    "sync-search:local": "pnpm exec tsx scripts/sync-search-local.ts",
    "verificar:prod": "bash scripts/verificar-produccion.sh",
    "diagnostico:prod": "bash scripts/diagnostico-produccion.sh",
    "verificar:deploy": "bash scripts/verificar-deploy-esperar.sh --wait 3",
    "prepare": "husky"
  },
  "devDependencies": {
    "argon2": "^0.31.2",
    "dotenv": "^16.4.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tsx": "^4.7.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
