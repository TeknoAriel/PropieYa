# Next.js solo carga `.env*` desde esta carpeta (`apps/web`), no desde la raíz del monorepo.
# Opciones:
#   1) Copiar el ejemplo de la raíz: `cp ../../.env.example .env.local` y ajustar rutas si hace falta
#   2) Pegar aquí al menos DATABASE_URL (misma que uses en local)
#
# Docker del repo (raíz): `docker compose up -d postgres` → Postgres en localhost:5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/propieya"
