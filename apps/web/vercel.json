{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm exec turbo run build --filter=@propieya/web --force",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/import-yumblin",
      "schedule": "0 6 1,16 * *"
    },
    {
      "path": "/api/cron/check-validity",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/listing-stale-content",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/cron/sync-search",
      "schedule": "0 4 * * *"
    }
  ]
}
