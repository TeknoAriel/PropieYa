# ========================================
# Propieya - Variables de Entorno
# ========================================
# Copia este archivo a .env.local y completa los valores

# ----------------------------------------
# Base de Datos (PostgreSQL)
# ----------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/propieya?schema=public"

# ----------------------------------------
# Elasticsearch
# ----------------------------------------
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_INDEX_PREFIX="propieya"

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_URL="redis://localhost:6379"

# ----------------------------------------
# LLM Provider
# ----------------------------------------
# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4-turbo-preview"

# Anthropic (alternativo)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# ----------------------------------------
# Storage (S3/R2/MinIO)
# ----------------------------------------
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="propieya-media"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/propieya-media"

# ----------------------------------------
# Auth
# ----------------------------------------
JWT_SECRET="CHANGE_THIS_IN_PRODUCTION_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARACTERS"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ----------------------------------------
# Email (Resend / Sendgrid / etc)
# ----------------------------------------
EMAIL_FROM="Propieya <noreply@propieya.com>"
RESEND_API_KEY=""
# SENDGRID_API_KEY=""

# ----------------------------------------
# App URLs
# ----------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PANEL_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
# Panel: URL de la app web (para llamar al API tRPC)
NEXT_PUBLIC_WEB_APP_URL="http://localhost:3000"

# ----------------------------------------
# Feature Flags
# ----------------------------------------
FEATURE_CONVERSATION_ENABLED="true"
FEATURE_MATCHING_ENABLED="true"

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
RATE_LIMIT_CONVERSATION_PER_MINUTE="20"
RATE_LIMIT_SEARCH_PER_MINUTE="60"

# ----------------------------------------
# Observability
# ----------------------------------------
LOG_LEVEL="debug"
# SENTRY_DSN=""
