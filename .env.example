# ========================================
# Propieya - Variables de Entorno
# ========================================
# Copia este archivo a .env.local y completa los valores.
#
# Producción (portal): proyecto Vercel propie-ya-web — las mismas claves en
# Settings → Environment Variables (Production). Sin DATABASE_URL el portal
# muestra listados vacíos y /api/health en 503. Ver docs/37-PRODUCCION-SPRINTS-E-IMPORTACION.md

# ----------------------------------------
# Base de Datos (PostgreSQL)
# ----------------------------------------
# Local: puerto 5433 (docker-compose). Producción: Neon u otro.
# Neon en Vercel: preferí la URL con host *-pooler.*.neon.tech (PgBouncer) para evitar
# CONNECT_TIMEOUT y límites de conexión; misma cadena en el proyecto web (Production).
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/propieya"
# Opcional: tope de conexiones por instancia (por defecto 10). Bajar si Neon marca demasiadas conexiones.
# DATABASE_POOL_MAX=5
# DATABASE_CONNECT_TIMEOUT_SEC=40
# Emergencia: desactivar inserts de telemetría en portal_stats_events (Sprints 45–48) sin redeploy de lógica
# DISABLE_PORTAL_STATS_WRITES=1

# ----------------------------------------
# Elasticsearch
# ----------------------------------------
# Local: docker-compose. Prod: Bonsai Sandbox gratis (docs/34-ELASTICSEARCH-BONSAI-CONFIG.md)
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_INDEX_PREFIX="propieya"
# Bonsai (OpenSearch): con URL *.bonsai.io el portal usa @opensearch-project/opensearch solo.
# Otro cluster OpenSearch: USE_OPENSEARCH=1. Forzar cliente Elasticsearch 8: SEARCH_BACKEND=elasticsearch
# USE_OPENSEARCH=1
# Opcional: en Vercel/staging, `1` loguea JSON de rendimiento de listing.search (fases es_done / sql_done / es_underfill_sql) y de searchConversational (conversation_search_done) en consola del servidor
# LOG_SEARCH_MS=1
# Opcional: `1` loguea JSON de telemetría de portal (p. ej. vista de ficha) con terminal_id — ver docs/49
# LOG_PORTAL_STATS=1

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_URL="redis://localhost:6379"

# ----------------------------------------
# LLM Provider — asistente home → searchConversational (docs/41-ASISTENTE-PORTAL.md)
# ----------------------------------------
# Opcional: sin clave, el asistente usa reglas locales (sigue funcionando).
# Recomendado costo/calidad: gpt-4o-mini
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Anthropic (alternativo)
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-sonnet-20240229"

# ----------------------------------------
# Storage (S3/R2/MinIO)
# ----------------------------------------
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="propieya-media"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/propieya-media"
# Web (Next.js images): hostname para remotePatterns (ej. pub-xxx.r2.dev)
NEXT_PUBLIC_MEDIA_HOST=""

# ----------------------------------------
# Cron (import Kiteprop / Properstar JSON)
# ----------------------------------------
CRON_SECRET=""
# Opcional: URL del feed JSON (default en código: Properstar static.kiteprop.com/.../properstar.json)
YUMBLIN_JSON_URL=""
# Opcional: lista de feeds (comma-separated) para sincronizar en el cron.
YUMBLIN_JSON_URLS=""
# Bajas: con un solo feed, `org` da de baja (withdrawn) todo aviso import de la org cuyo external_id ya no está en el JSON. `source` = solo avisos del mismo import_feed_sources (legado).
IMPORT_WITHDRAW_SCOPE="org"
# Mínimo de horas entre dos syncs reales (admite decimales: 0.5 = 30 min). 0 o negativo = sin mínimo (cada tick del cron corre).
# Producción con cron cada 30 min: 0. Prueba / baja frecuencia: 48 (u omitir cron en previews — ver docs/48).
IMPORT_SYNC_INTERVAL_HOURS="1"
# Secret opcional para POST /api/webhooks/kiteprop-ingest (si vacío, se usa CRON_SECRET).
KITEPROP_INGEST_WEBHOOK_SECRET=""

# ----------------------------------------
# Publicación de avisos + vencimiento por contenido (KiteProp / portal)
# ----------------------------------------
# Mínimo de fotos para publicar (import + publish manual).
# LISTING_MIN_PHOTOS="1"
# LISTING_MIN_TITLE_LENGTH="10"
# LISTING_MIN_DESCRIPTION_LENGTH="50"
# Días sin actualización de contenido en publicación → estado `expired` (cron GET /api/cron/listing-stale-content).
# LISTING_STALE_CONTENT_DAYS="30"
# Precios numéricos tratados como placeholder (lista separada por comas).
# LISTING_UNSUPPORTED_PRICE_AMOUNTS="1,10,100,9999"
# Webhook opcional: POST JSON `KitepropListingLifecyclePayloadV1` por cada evento en `listing_lifecycle_events` (outbox).
# KITEPROP_LISTING_LIFECYCLE_WEBHOOK_URL=""
# KITEPROP_LISTING_LIFECYCLE_WEBHOOK_SECRET=""

# ----------------------------------------
# KiteProp API + MCP (CRM / asistente integraciones)
# ----------------------------------------
# REST: todas las llamadas server-side con header X-API-Key.
# KITEPROP_API_TOKEN es alias soportado (misma clave que en docs MCP).
# KITEPROP_API_KEY=""
# KITEPROP_API_BASE_URL="https://www.kiteprop.com/api/v1"
# Rutas REST opcionales si la API cambia:
# KITEPROP_PATH_PROFILE="profile"
# KITEPROP_PATH_PROPERTIES="properties"
# KITEPROP_PATH_CONTACTS="contacts"
# KITEPROP_PATH_MESSAGES="messages"
# Legacy (compatibilidad): KITEPROP_PATH_LEADS="leads"
# Timeouts/retries HTTP server-side para KiteProp.
# KITEPROP_REQUEST_TIMEOUT_MS="10000"
# KITEPROP_REQUEST_RETRIES="1"
# Enriquecimiento runtime de contacto asignado en ficha (usa API por externalId si falta en DB).
# KITEPROP_ENRICH_LISTING_CONTACT="0"
# Sync de consultas/leads hacia KiteProp:
# - por defecto queda desactivado hasta confirmar contrato final de payload.
# KITEPROP_ENABLE_INQUIRY_POST="0"
# KITEPROP_ENABLE_MESSAGE_POST="0"
# Ingest masivo (cron / import:yumblin): auto = feed JSON por defecto; si YUMBLIN_JSON_URL apunta al listado REST en kiteprop.com y hay API key, se usa paginación API. api = solo GET paginado a properties. both = API + URLs en YUMBLIN_JSON_URLS. json = siempre GET JSON del feed (sin paginado API).
# KITEPROP_INGEST_MODE="auto"
# KITEPROP_INGEST_PER_PAGE="100"
# Filtros del listado (ej. status=published); se añaden a cada página junto a page y per_page.
# KITEPROP_INGEST_PROPERTIES_QUERY=""
# MCP remoto (herramientas search_properties / search_messages):
# KITEPROP_MCP_URL="https://mcp.kiteprop.com/mcp"
# POST /api/assistant/query — en producción obligatorio; header x-assistant-query-secret
# KITEPROP_ASSISTANT_QUERY_SECRET=""
# Smoke: permitir POST de lead de prueba con scripts/kiteprop-integration-smoke.ts
# KITEPROP_SMOKE_CREATE_LEAD="0"

# Si es "false", cada llamada al cron ejecuta sync (ignora IMPORT_SYNC_INTERVAL_HOURS). Default: aplicar intervalo.
IMPORT_SYNC_ENFORCE_INTERVAL=""
# Modo prueba: si se activa, el intervalo real pasa a 10 días (o IMPORT_SYNC_TEST_INTERVAL_DAYS).
IMPORT_SYNC_TEST_MODE="false"
IMPORT_SYNC_TEST_INTERVAL_DAYS="10"
# Si "true", los avisos nuevos del feed quedan en draft (comportamiento antiguo). Default: false = active + vigencia (catálogo visible en portal).
IMPORT_INGEST_AS_DRAFT=""

# ----------------------------------------
# Auth
# ----------------------------------------
JWT_SECRET="CHANGE_THIS_IN_PRODUCTION_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARACTERS"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ----------------------------------------
# Email (Resend / Sendgrid / etc)
# ----------------------------------------
EMAIL_FROM="Propieya <noreply@propieya.com>"
RESEND_API_KEY=""
# SENDGRID_API_KEY=""

# ----------------------------------------
# App URLs
# ----------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3010"
NEXT_PUBLIC_PANEL_URL="http://localhost:3011"
# Opcional: se muestra en /contacto del portal web
NEXT_PUBLIC_CONTACT_EMAIL=""
NEXT_PUBLIC_API_URL="http://localhost:3010/api"
# Panel: URL de la app web (para llamar al API tRPC)
NEXT_PUBLIC_WEB_APP_URL="http://localhost:3010"

# Web (Vercel): orígenes del panel permitidos para CORS en /api/trpc (coma, sin espacios extra)
# Ej producción: TRUSTED_PANEL_ORIGINS="https://tu-panel.vercel.app"
TRUSTED_PANEL_ORIGINS="http://localhost:3011"

# Web: magic link de prueba (panel). En producción real dejar vacío o 0.
# Local: usar 1 para login rápido sin registrar
MAGIC_LINK_TEST_MODE=""

# Web: pack de copy del portal (A/B). conversacion_primero | regla_portal_v1 | variante_b_cercano
NEXT_PUBLIC_PORTAL_COPY_PACK="conversacion_primero"

# Web: mostrar título del pack arriba (solo pruebas UX)
NEXT_PUBLIC_SHOW_COPY_PACK_LABEL=""

# Web: memoria de sesión del asistente en /buscar (banner, chips, previousContext). Por defecto activo; `0` la desactiva (docs/47 §F3)
# NEXT_PUBLIC_ENABLE_CONVERSATIONAL_SESSION_CONTEXT=0

# Panel: mostrar UI de magic link en /login (requiere MAGIC_LINK_TEST_MODE en web)
# Local: usar 1 para ver el bloque de magic link
NEXT_PUBLIC_MAGIC_LINK_TEST_MODE=""

# ----------------------------------------
# Pagos — Mercado Pago (monetización futura)
# ----------------------------------------
# Webhook: POST /api/payments/mercadopago/webhook — ver docs/39-MONETIZACION-MERCADOPAGO.md
# MERCADOPAGO_ACCESS_TOKEN=""
# MERCADOPAGO_PUBLIC_KEY=""
# MERCADOPAGO_WEBHOOK_SECRET=""
# Margen de reloj para ts del header (ms). Default 600000. "0" = sin validar antigüedad.
# MERCADOPAGO_WEBHOOK_TS_SKEW_MS=""
# MERCADOPAGO_CLIENT_ID=""
# MERCADOPAGO_CLIENT_SECRET=""

# Panel: sumar créditos de activación de leads sin cobro real (dev: activo si no se define).
# Producción: definir 1/true para habilitar; 0/false para desactivar explícitamente.
# LEAD_CREDITS_SIMULATED_PURCHASE="1"

# ----------------------------------------
# Feature Flags
# ----------------------------------------
FEATURE_CONVERSATION_ENABLED="true"
FEATURE_MATCHING_ENABLED="true"

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
RATE_LIMIT_CONVERSATION_PER_MINUTE="20"
RATE_LIMIT_SEARCH_PER_MINUTE="60"

# ----------------------------------------
# Observability
# ----------------------------------------
LOG_LEVEL="debug"
# SENTRY_DSN=""
